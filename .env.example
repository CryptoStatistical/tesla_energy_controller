# Avvio sempre sicuro: in dry-run i comandi Tesla non vengono inviati.
MODE=dry-run
CONTROL_MODE=solar-production
POLL_INTERVAL_SECONDS=300

# mock | alfa-modbus | solaredge-web | solaredge-modbus | solaredge-cloud
# Default operativo: Modbus TCP locale. Usare mock solo per sviluppo/test senza hardware.
ENERGY_SOURCE=solaredge-modbus
EXPECTED_PHASES=3
NOMINAL_PHASE_VOLTAGE_V=230
MIN_VOLTAGE_V=200
MAX_VOLTAGE_V=255
SOLAR_UTILIZATION_PERCENT=100
SOLAR_TIMEZONE=Europe/Rome
# Sede fissa Vittorio Veneto (TV): non spostabile, non esposta nel pannello.
# Usate solo dalla modalità alba/tramonto.
SOLAR_LATITUDE=45.9869
SOLAR_LONGITUDE=12.3045
TARGET_GRID_IMPORT_W=200
GRID_IMPORT_LIMIT_W=3000
GRID_IMPORT_EMERGENCY_W=3300
GRID_HOLD_BAND_W=200
GRID_SURPLUS_STABLE_READS=3
# Con lettura ALFA attiva: obiettivo economico della massima media su 15 minuti.
POWER_QUOTA_TARGET_W=7000
POWER_QUOTA_HYSTERESIS_W=500

# DA VERIFICARE sul magnetotermico/contratto e sul Wall Connector.
MAX_GRID_CURRENT_A=25
MIN_CHARGE_AMPS=5
MAX_CHARGE_AMPS=16
MANUAL_OVERRIDE_AMPS=14
EXTRA_GRID_POWER_W=3000
COMMAND_HYSTERESIS_A=1
MAX_RAMP_UP_A=2

# SolarEdge Modbus TCP (tipicamente porta 1502, unit ID 1).
# Questo e' un refresh/keepalive leggero, non il campionamento SQLite.
# SolarEdge dichiara idle TCP 2 minuti: tenere 10-110s, consigliato 30s.
# Lasciare vuoto solo se si usa solaredge-web, solaredge-cloud o mock.
SOLAREDGE_MODBUS_HOST=192.168.2.126
SOLAREDGE_MODBUS_PORT=1502
SOLAREDGE_MODBUS_UNIT=1
SOLAREDGE_MODBUS_POLL_INTERVAL_SECONDS=30
SOLAREDGE_INVERTER_BASE=40069
SOLAREDGE_METER_BASE=40121
# 1 = lettura positiva in import; -1 se il verso risulta invertito.
SOLAREDGE_GRID_POWER_SIGN=1

# ALFA by Sinapsi Modbus TCP. Usare con ENERGY_SOURCE=alfa-modbus e
# CONTROL_MODE=meter-closed-loop dopo verifica registri su Catena 2 M1.
# POLL_INTERVAL_SECONDS=300 produce tre campioni da 5 minuti per ogni quarto d'ora.
ALFA_MODBUS_HOST=
ALFA_MODBUS_PORT=502
ALFA_MODBUS_UNIT=1
ALFA_MODBUS_TIMEOUT_SECONDS=5
# Feedback import/export rapido; la quota resta aggregata in slot da 5 minuti.
ALFA_CONTROL_INTERVAL_SECONDS=30

# Login portale web privato. Il file .env è escluso da Git.
SOLAREDGE_SITE_ID=4508922
SOLAREDGE_USERNAME=
SOLAREDGE_PASSWORD=
# In alternativa alle due righe sopra:
SOLAREDGE_USERNAME_FILE=
SOLAREDGE_PASSWORD_FILE=
# Sessione SolarEdge persistita: al riavvio riusa il token (refresh leggero) invece
# di rifare il login OAuth completo. Tenere fuori dal versionamento (contiene token).
SOLAREDGE_SESSION_FILE=.secrets/solaredge_session.json

# Alternativa cloud (massimo una chiamata ogni 300 secondi).
CLOUD_POLL_INTERVAL_SECONDS=300
SOLAREDGE_API_KEY_FILE=.secrets/solaredge_api_key

# Vimar By-me Plus / AG+ IP Connector.
# Usato per associare il client terze parti e leggere i misuratori Energy.
VIMAR_HOST=
VIMAR_PORT=20615
VIMAR_DEVICE_UID=
VIMAR_CLIENT_NAME="Raspberry Energy Monitor"
VIMAR_THIRD_PARTY_TAG=
VIMAR_SETUP_CODE=
VIMAR_SETUP_CODE_FILE=
VIMAR_PRIVATE_KEY_FILE=.secrets/vimar_private_key.pem
VIMAR_PUBLIC_KEY_FILE=.secrets/vimar_public_key.pem
VIMAR_CREDENTIALS_FILE=.secrets/vimar_credentials.json
VIMAR_CA_CERT=.secrets/VimarCA.cert.pem
VIMAR_TLS_VERIFY=true
VIMAR_TLS_CHECK_HOSTNAME=false
VIMAR_TIMEOUT_SECONDS=15
# AG+ aggiornato espone protocollo 3.0; usare 2.7 solo con firmware più vecchi.
VIMAR_PROTOCOL_VERSION=3.0

# Tesla: mock durante i test; sul Raspberry vicino all'auto usare BLE locale.
# Non servono Fleet API, OAuth, dominio pubblico o abbonamenti Tesla.
TESLA_MOCK=true
TESLA_TRANSPORT=mock
TESLA_VIN=
TESLA_CONTROL_BINARY=tesla-control
TESLA_BLE_KEY_FILE=.secrets/tesla/private-key.pem
TESLA_BLE_CACHE_FILE=.secrets/tesla/session-cache.json
TESLA_BLE_TIMEOUT_SECONDS=35
TESLA_BLE_CONNECT_TIMEOUT_SECONDS=20
TESLA_BLE_COMMAND_TIMEOUT_SECONDS=10
TESLA_BLE_RETRIES=3
TESLA_BLE_RETRY_BACKOFF_SECONDS=1
TESLA_BLE_ADAPTER=hci0
TESLA_BLE_REQUIRE_TIME_SYNC=true
TESLA_BLE_PREFLIGHT_SLEEP_CHECK=true
# Timeout, retry e recovery sono ritoccabili anche dal pannello web.
# Attivare recovery sul Raspberry dopo avere verificato che bluetoothctl funzioni per l'utente servizio.
TESLA_BLE_RECOVERY_ENABLED=false
TESLA_BLE_RECOVERY_THRESHOLD=3

# Non configurare Fleet API per l'installazione BLE locale.
TESLA_CLIENT_ID=
TESLA_API_BASE_URL=
TESLA_CA_CERT=.secrets/tesla/cert.pem
TESLA_VERIFY_SSL=true
TESLA_TOKEN_FILE=.secrets/tesla_tokens.json

# Solo per la prova senza hardware.
MOCK_GRID_POWER_W=-2000
MOCK_SOLAR_POWER_W=5000
MOCK_TESLA_CURRENT_A=6

# TuyaLink / Smart Life. Usare lo stesso data center dell'account app.
# EU/Italia: m1.tuyaeu.com. China: m1.tuyacn.com.
TUYA_ENABLED=true
TUYA_DATA_CENTER=eu
TUYA_MQTT_HOST=m1.tuyaeu.com
TUYA_MQTT_PORT=8883
TUYA_PRODUCT_ID=
TUYA_DEVICE_ID=
TUYA_DEVICE_SECRET=
TUYA_DEVICE_SECRET_FILE=
TUYA_KEEPALIVE_SECONDS=60
TUYA_REPORT_INTERVAL_SECONDS=20
TUYA_AVERAGE_SAMPLES=3
TUYA_REPORT_TESLA=true

# Pannello web. Inserire la password reale solo nel file .env non tracciato.
SECRET_KEY=
WEB_PASSWORD=
WEB_USERNAME=admin
WEB_VIEWER_USERNAME=utente
WEB_VIEWER_PASSWORD=
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_SECURE_COOKIE=false
WEB_SESSION_TTL_SECONDS=43200
RUNTIME_SETTINGS_FILE=data/runtime_settings.json
ENERGY_DATABASE_FILE=data/energy.sqlite3
DATA_RETENTION_DAYS=90

# Eventi via mail: controller acceso/spento, override manuale.
EVENT_EMAIL_ENABLED=false
EVENT_EMAIL_COOLDOWN_SECONDS=1800
NOTIFY_BACKEND=wordpress
NOTIFY_RECIPIENTS=
NOTIFY_API_URL=https://example.com/wp-json/custom/v1/send-email
NOTIFY_API_KEY=
NOTIFY_API_KEY_FILE=
NOTIFY_API_USER=
NOTIFY_API_USER_FILE=
NOTIFY_SENDER_NAME="Tesla Energy Controller"
NOTIFY_REPLY_TO=noreply@example.com
NOTIFY_TIMEOUT_SECONDS=15

# Alternativa SMTP: impostare NOTIFY_BACKEND=smtp. Autenticazione opzionale.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_USERNAME_FILE=
SMTP_PASSWORD=
SMTP_PASSWORD_FILE=
SMTP_FROM=
SMTP_STARTTLS=true
SMTP_SSL=false

# Report errori via email. Di default è disabilitato.
ERROR_REPORT_EMAIL_ENABLED=false
ERROR_REPORT_EMAIL_ON_SOLAREDGE_FAILURE=true
ERROR_REPORT_EMAIL_COOLDOWN_SECONDS=3600
